{
  "name": "openextract",
  "version": "0.1.0",
  "description": "Free, open-source iPhone backup extractor",
  "main": "dist-electron/main.js",
  "author": "OpenExtract Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "python:install": "cd python && pip install -r requirements.txt",
    "python:bundle": "cd python && pyinstaller --onefile --name openextract-engine main.py"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openextract.app",
    "productName": "OpenExtract",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*.js",
      "python/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "python/dist/openextract-engine",
        "to": "python/openextract-engine"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  }
}
